    },
    "m_Name": "VATSamplePositionAtlas (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -495.199951171875,
            "y": -2.3999791145324709,
            "width": 292.7999572753906,
            "height": 357.6000061035156
        }
    },
    "m_Slots": [
        {
            "m_Id": "41c630815c8c4c69879df0f301ba1e38"
        },
        {
            "m_Id": "9a1a75908530416fbf2336dc2bbb5471"
        },
        {
            "m_Id": "c83292ca771f4b16a36e6296a0cde833"
        },
        {
            "m_Id": "1df885a424f64f6da4678ebdba023c39"
        },
        {
            "m_Id": "910287254d524f10bd2917c0c7a23a25"
        },
        {
            "m_Id": "0b3c796570b9443da512b89df1fb12f2"
        },
        {
            "m_Id": "62e043ec96e2427f8a9ee28ce00bb548"
        },
        {
            "m_Id": "8fdd837dc54343e2ae58264b270e6646"
        },
        {
            "m_Id": "a8580eb52a264979a07f7091a9891649"
        },
        {
            "m_Id": "ca5fe18cbc1b48ab9dc5d9f9c1791233"
        },
        {
            "m_Id": "dde60dd5c6614b1f960c8481c3ac74fa"
        },
        {
            "m_Id": "838226d86d7043d88b5e946cf311d3de"
        },
        {
            "m_Id": "262433ab8ede45efb5c5bb872417007c"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "VATSamplePositionAtlas",
    "m_FunctionSource": "a9d08e5fb2bf54d41a2b67ca4eeda97b",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float metaU = (AnimID + 0.5) / AnimCount;\r\nfloat4 meta = SAMPLE_TEXTURE2D_LOD(MetaTex.tex, MetaSampler.samplerstate, float2(metaU, 0.5), 0);\r\nfloat startFrame = meta.r;\r\nfloat frameCount = meta.g;\r\nfloat fps = meta.b;\r\n\r\nfloat localFrame = fmod(ElapsedTime * fps, frameCount);\r\nfloat frameF = frac(localFrame);\r\nfloat frameA = floor(localFrame);\r\nfloat frameB = fmod(frameA + 1.0, frameCount);\r\n\r\nfloat vertU = (VertexID + 0.5) / VertexCount;\r\nfloat2 uvA = float2(vertU, (startFrame + frameA + 0.5) / TotalAtlasFrames);\r\nfloat2 uvB = float2(vertU, (startFrame + frameB + 0.5) / TotalAtlasFrames);\r\n\r\nfloat3 pA = SAMPLE_TEXTURE2D_LOD(PosTex.tex, PosSampler.samplerstate, uvA, 0).rgb;\r\nfloat3 pB = SAMPLE_TEXTURE2D_LOD(PosTex.tex, PosSampler.samplerstate, uvB, 0).rgb;\r\nPosition = lerp(pA, pB, frameF) * PosRange + PosMin;"
}

