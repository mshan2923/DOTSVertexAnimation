{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "b5d04f7c51e54dbd8e76de801d485e2a",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "VATSampleAtlasTest (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -473.5999450683594,
            "y": 370.3999938964844,
            "width": 271.199951171875,
            "height": 340.8000183105469
        }
    },
    "m_Slots": [
        {
            "m_Id": "a1ef72524387452c9a80024bf658854b"
        },
        {
            "m_Id": "82327a53a15e41ec8bbe6f373b6990d0"
        },
        {
            "m_Id": "50194799311b4839a0187aed67eb40ad"
        },
        {
            "m_Id": "babb601ac3a3477ca7939ddf20d4eab7"
        },
        {
            "m_Id": "848ccd7935db448f9721061a98f37150"
        },
        {
            "m_Id": "820e9e9597424f9ea4d8f78b44093b0f"
        },
        {
            "m_Id": "25b04834765d428c881b16b975bfdf16"
        },
        {
            "m_Id": "67270fb7b1284c76b282d70c933e3db3"
        },
        {
            "m_Id": "288474982d884a6ba20cc9549b384184"
        },
        {
            "m_Id": "826cfaa340cd488b8e066dc4b6e53ebf"
        },
        {
            "m_Id": "e2193e7120554340a259e728f38f9287"
        },
        {
            "m_Id": "78e8f8a2f4364e1e87dac04d45b3cb50"
        },
        {
            "m_Id": "6d212bcb8c0f4d2f8997fd2bb1fab111"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "VATSampleAtlasTest",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float metaU = (AnimID + 0.5) / AnimCount;\r\nfloat4 meta = SAMPLE_TEXTURE2D_LOD(MetaTex.tex, MetaSampler.samplerstate, float2(metaU, 0.5), 0);\r\nfloat startFrame = meta.r;\r\nfloat frameCount = meta.g;\r\nfloat fps = meta.b;\r\n\r\nfloat localFrame = fmod(ElapsedTime * fps, frameCount);\r\nfloat frameF = frac(localFrame);\r\nfloat frameA = floor(localFrame);\r\nfloat frameB = fmod(frameA + 1.0, frameCount);\r\n\r\nfloat vertU = (VertexID + 0.5) / VertexCount;\r\nfloat2 uvA = float2(vertU, (startFrame + frameA + 0.5) / TotalAtlasFrames);\r\nfloat2 uvB = float2(vertU, (startFrame + frameB + 0.5) / TotalAtlasFrames);\r\n\r\nfloat3 pA = SAMPLE_TEXTURE2D_LOD(PosTex.tex, PosSampler.samplerstate, uvA, 0).rgb;\r\nfloat3 pB = SAMPLE_TEXTURE2D_LOD(PosTex.tex, PosSampler.samplerstate, uvB, 0).rgb;\r\nPosition = lerp(pA, pB, frameF) * PosRange + PosMin;"
}

